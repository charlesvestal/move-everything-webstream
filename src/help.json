{
  "title": "Webstream",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Web audio search",
        "and streaming.",
        "",
        "Search and play",
        "audio from YouTube,",
        "FreeSound, Archive,",
        "and SoundCloud.",
        "",
        "Requires internet",
        "connection."
      ]
    },
    {
      "title": "Controls",
      "children": [
        {
          "title": "Playback Knobs",
          "lines": [
            "Touch a knob then",
            "turn right to",
            "confirm action:",
            "",
            "Knob 1: Play/Pause",
            "Knob 2: Rewind 15s",
            "Knob 3: Forward 15s",
            "Knob 7: Stop",
            "Knob 8: Restart",
            "",
            "Turn left to cancel."
          ]
        },
        {
          "title": "Searching",
          "lines": [
            "Select [New Search]",
            "from the menu to",
            "enter a query.",
            "",
            "Providers:",
            " [YT] YouTube",
            " [FS] FreeSound",
            " [AR] Archive.org",
            " [SC] SoundCloud",
            " [CD] Crate Dig",
            "",
            "Up to 20 results",
            "per search.",
            "",
            "Search history",
            "saved (max 20)."
          ]
        },
        {
          "title": "Crate Dig",
          "lines": [
            "Random music",
            "discovery powered",
            "by Discogs.",
            "",
            "Filter by genre,",
            "style, decade, and",
            "country. Hit [Dig!]",
            "for random tracks.",
            "",
            "Finds releases on",
            "Discogs with YouTube",
            "videos and plays",
            "them directly.",
            "",
            "Uses Discogs API.",
            "Optional: add your",
            "own token for higher",
            "rate limits (60/min",
            "vs 25/min).",
            "",
            "Add token to config:",
            "webstream_providers",
            ".json with:",
            "{\"providers\":",
            " {\"cratedig\":",
            "  {\"token\":\"...\"}}}",
            "",
            "Get a free token at",
            "discogs.com/settings",
            "/developers"
          ]
        }
      ]
    },
    {
      "title": "Playback",
      "lines": [
        "Select a result to",
        "start streaming.",
        "",
        "Status indicator:",
        " Loading: resolving",
        " Buffering: filling",
        " Streaming: playing",
        " Paused: paused",
        " Seeking: skipping",
        "",
        "Gain: 0-2x output",
        "level.",
        "",
        "60-second ring",
        "buffer prevents",
        "audio dropouts."
      ]
    }
  ]
}
